<%- include('./partial/header.ejs') %>


<div class="container">
    <div class="row">
        <div class="col-sm-6 mt-5">
            <h2 class="alert alert-success text-center">Add New Student</h2>

<form action="/admin" method="post" enctype="multipart/form-data">
    <div class="form-group">
      <label for="name">Name:</label>
      <input type="text" class="form-control" id="name" placeholder="Enter your name" name="name">
    </div>
    <div class="form-group">
      <label for="age">Age:</label>
      <input type="number" class="form-control" id="age" placeholder="Enter your age" name="age">
    </div>
    <div class="form-group">
      <label for="fee">Fee:</label>
      <input type="number" class="form-control" id="fees" placeholder="Enter the fee" name="fees">
    </div>
    <div class="form-group">
        <label for="fee">Img:</label>
        <input type="file" class="form-control" id="img" placeholder="Enter the img" name="img">
      </div>
    <button type="submit" class="btn btn-primary">Submit</button>
  </form>


        </div>
        <div class="col-sm-6 mt-5">
            <h2 class="alert alert-success text-center">
                List of Student
            </h2>
            <table class="table table-bordered">
    <thead>
      <tr>
        <th>No</th>
        <th>Name</th>
        <th>Age</th>
        <th>Fee</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
        <% var i =1 %>
        <% data.forEach((item)=>{  %>
            <td><%= i++ %></td>
            <td><%= item.name %></td>
            <td><%= item.age %></td>
            <td><%= item.fees %></td>
            <td>
                <form action="/admin/edit/<%= item._id %>" method="get" class="d-inline">
            <button type="submit" class="btn">
                <i class="fa fa-pencil"></i>
            </button>
        </form>


        <form action="/admin/delet/<%= item._id %>" method="post" class="d-inline">
            <button type="submit" class="btn">
                <i class="fa fa-trash danger"></i>
            </button>
        </form>
             
            </td>

<td>
    <img src="<%= item.img %>" width="200" height="200">
</td>


          </tr>
      <%  }) %>
      <tr>
        
      <!-- Add more rows as needed -->
    </tbody>
  </table>





        </div>
    </div>
</div>
    

    

    <%- include('./partial/footer.ejs') %>
   

  