<%- include('./partial/header.ejs') %>




<div class="container">
    <div class="row">
        <div class="col-sm-6 mt-5">
            <h2 class="alert alert-success text-center">update Student</h2>

<form method="post" action="/admin/update/<%= data._id %>">
    <div class="form-group">
      <label for="name">Name:</label>
      <input type="text" class="form-control" id="name" placeholder="Enter your name" name="name" value="<%= data.name %>">
    </div>
    <div class="form-group">
      <label for="age">Age:</label>
      <input type="number" class="form-control" id="age" placeholder="Enter your age" name="age" value="<%= data.age %>">
    </div>
    <div class="form-group">
      <label for="fee">Fee:</label>
      <input type="number" class="form-control" id="fees" placeholder="Enter the fee" name="fees" value="<%= data.fees %>">
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
  </form>


        </div>
    </div></div>











<%- include('./partial/footer.ejs') %>