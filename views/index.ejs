<%- include('./partial/header.ejs') %>


<div class="container">


  <nav class="navbar navbar-expand-lg navbar-light bg-light">

    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
  
    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav mr-auto">
        <li class="nav-item">
          <a class="nav-link" href="#">Chicken <span class="sr-only">(current)</span></a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#">Mutton</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#">Beef</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#">SeaFood</a>
        </li>
       
      
      </ul>
   
    </div>
  </nav>




    <div class="row">
        <div class="col-sm-6 mt-5">
            <h2 class="alert alert-success text-center">Add New chicken</h2>

<form action="/admin" method="post" enctype="multipart/form-data">
    <div class="form-group">
      <label for="title">Title:</label>
      <input type="text" class="form-control" id="title" placeholder="Enter your title" name="title">
    </div>
    <div class="form-group">
      <label for="price">Price:</label>
      <input type="number" class="form-control" id="price" placeholder="Enter your price" name="price">
    </div>
    
    <div class="form-group">
        <label for="fee">Img:</label>
        <input type="file" class="form-control" id="img" placeholder="Enter the img" name="img">
      </div>
    <button type="submit" class="btn btn-primary">Submit</button>
  </form>


        </div>
        <div class="col-sm-6 mt-5">
            <h2 class="alert alert-success text-center">
                List of Chicken
            </h2>
            <table class="table table-bordered">
    <thead>
      <tr>
        <th>No</th>
        <th>Title</th>
        <th>Price</th>
       
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
        <% var i =1 %>
        <% data.forEach((item)=>{  %>
            <td><%= i++ %></td>
            <td><%= item.title %></td>
            <td><%= item.price %></td>
            
            <td>
                <form action="/admin/edit/<%= item._id %>" method="get" class="d-inline">
            <button type="submit" class="btn">
                <i class="fa fa-pencil"></i>
            </button>
        </form>


        <form action="/admin/delet/<%= item._id %>" method="post" class="d-inline">
            <button type="submit" class="btn">
                <i class="fa fa-trash danger"></i>
            </button>
        </form>
             
            </td>

<td>
    <img src="<%= item.img %>" width="200" height="200">
</td>


          </tr>
      <%  }) %>
      <tr>
        
      <!-- Add more rows as needed -->
    </tbody>
  </table>





        </div>
    </div>







